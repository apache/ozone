        "includeAll": false,
        "label": "filter active",
        "multi": false,
        "name": "filter_active",
        "options": [],
        "query": {
          "query": "query_result(count(ozone_build_info) - count(ozone_build_info{component=~\"$component\",instance=~\"$instance\"}))",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "/\\}\\s+([1-9]\\d*)\\s+\\d+$/",
        "sort": 0,
        "type": "query"
